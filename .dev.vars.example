# Google Ads API Credentials
# Copy this file to .dev.vars and fill in your actual credentials

# OAuth2 Client ID from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret from Google Cloud Console
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# OAuth2 Refresh Token (generated via OAuth flow)
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Google Ads API Developer Token (from Google Ads account)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Login Customer ID (optional, for manager accounts)
# Format: 1234567890 (without dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_customer_id_here

